{
  "name": "secure-file-share-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Production-oriented secure file sharing platform backend with Vite frontend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "jest --runInBand",
    "test:backend": "jest --runInBand tests/backend",
    "test:frontend": "npm --prefix frontend run test",
    "client:dev": "npm --prefix frontend run dev",
    "client:build": "npm --prefix frontend run build",
    "client:test": "npm --prefix frontend run test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.873.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.2.0",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/backend/**/*.test.js"
    ],
    "testTimeout": 30000
  }
}
